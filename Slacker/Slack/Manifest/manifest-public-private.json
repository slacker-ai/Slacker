{
  "display_information": {
    "name": "Slacker",
    "description": "Local-first catch-up: surfaces missed follow-ups, stale items, and mentions in your own channels. All processing stays on your machine.",
    "background_color": "#2c2d30"
  },
  "oauth_config": {
    "scopes": {
      "user": [
        "channels:history",
        "channels:read",
        "groups:history",
        "groups:read",
        "reactions:read",
        "users:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "user_events": [
        "message.channels",
        "message.groups",
        "reaction_added",
        "reaction_removed"
      ]
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
